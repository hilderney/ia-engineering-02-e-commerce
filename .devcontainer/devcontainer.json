// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/java
{
  "name": "UNIPDS - Engenharia de IA Aplicada",
  
  // Use a Dockerfile or Docker Compose file. More info: https://containers.dev/guide/dockerfile
  "build": {
    // Path is relative to the devcontainer.json file.
    "dockerfile": "Dockerfile"
  },
  "workspaceFolder": "/workspaces",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspaces,type=bind",

  "features": {
    // More options: https://github.com/devcontainers/features/tree/main/src/docker-outside-of-docker#options
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {},
    // More options: https://github.com/devcontainers/features/tree/main/src/node#options
    "ghcr.io/devcontainers/features/node:1": {
      "version": "22"
    },
    // More options: https://github.com/devcontainers/features/tree/main/src/python#options
    "ghcr.io/devcontainers/features/python:1": {
      "version": "3.11"
    }
    // More options: https://github.com/devcontainers/features/tree/main
  },

  // Use 'runArgs' to make an array of Docker CLI arguments that should be used when running the container.
  // "runArgs": [],

  // Use 'forwardPorts' to make a list of ports inside the container available locally.
  // "forwardPorts": [],

  // Use 'initializeCommand' to run commands locally before the container is created.
//   "initializeCommand": ".devcontainer/commands/initialize.sh",

  // Use 'postCreateCommand' to run commands after the container is created.
//   "postCreateCommand": ".devcontainer/commands/post-create.sh",

  // Configure tool-specific properties.
  "customizations": {
    "vscode": {
      "settings": {},
      // Add extensions to the container image.
      "extensions": [
        "ms-azuretools.vscode-docker"
      ]
    }
  }

  // Uncomment to connect as root instead. More info: https://aka.ms/dev-containers-non-root.
  // "remoteUser": "root"
}